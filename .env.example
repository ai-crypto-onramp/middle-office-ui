# HTTP port the Vite preview/nginx server listens on
PORT=3000
NODE_ENV=production

# Backend service base URLs (called directly via REST from the SPA)
VITE_IDENTITY_AUTH_URL=http://identity-auth.internal:8080
VITE_ONBOARDING_KYC_URL=http://onboarding-kyc.internal:8080
VITE_AML_KYT_URL=http://aml-kyt-screening.internal:8080
VITE_POLICY_ENGINE_URL=http://policy-risk-engine.internal:8080
VITE_FRAUD_URL=http://fraud-detection.internal:8080
VITE_AUDIT_URL=http://audit-event-log.internal:8080

# Optional telemetry
VITE_OTEL_ENDPOINT=
VITE_SENTRY_DSN=